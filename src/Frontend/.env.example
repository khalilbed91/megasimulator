# Copy to .env.local (not committed). Vite exposes only VITE_* to the client.
# Google OAuth Web client ID (same as Google Cloud Console → APIs & Services → Credentials).
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Public origin for sitemap.xml + robots.txt at build time (no trailing slash).
# Example: https://app.mondomaine.fr
VITE_PUBLIC_SITE_URL=http://localhost:5173
